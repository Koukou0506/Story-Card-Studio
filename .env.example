# ============================================
# Story Card Studio - 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入你的 API 密钥

# OpenAI API 密钥（用于 OpenAI Provider）
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API 密钥（用于 Anthropic Provider）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# 默认模型供应商: "openai" | "anthropic" | "mock"
# 不设置或设为 "mock" 时使用 Mock Provider（不需要 API 密钥）
DEFAULT_PROVIDER=mock

# 服务端 API 超时时间（毫秒）
API_TIMEOUT_MS=60000
